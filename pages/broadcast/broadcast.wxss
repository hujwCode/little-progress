.broadcast-input-wrap {
  display: flex; align-items: center; gap: 8px;
  background: var(--bg-card); border-radius: var(--radius-sm);
  padding: 12px 16px; margin-bottom: 16px; border: 1px solid var(--border);
}
.broadcast-emoji { font-size: 1.2em; flex-shrink: 0; }
.broadcast-input { flex: 1; border: none; font-size: 0.9em; background: transparent; color: var(--text); height: 36px; }
.send-btn { background: var(--accent-dark); color: white; border: none; border-radius: 8px; padding: 6px 16px; font-size: 0.85em; flex-shrink: 0; line-height: 1.8; }
.send-btn::after { border: none; }
.send-btn[disabled] { opacity: 0.5; }
.broadcast-list { display: flex; flex-direction: column; gap: 10px; }
.broadcast-item { display: flex; gap: 10px; align-items: flex-start; background: var(--bg-card); border-radius: var(--radius-sm); padding: 14px 16px; border: 1px solid var(--border); }
.b-user-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--bg-secondary); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 1.1em; }
.b-content { flex: 1; min-width: 0; }
.b-text { font-size: 0.88em; color: var(--text); line-height: 1.5; }
.b-name { font-weight: 600; }
.b-meta { font-size: 0.75em; color: var(--text-muted); margin-top: 3px; }
