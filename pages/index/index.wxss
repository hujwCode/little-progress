.page-user-select {
  display: flex; align-items: center; justify-content: center;
  min-height: 100vh; padding: 24px; background: var(--bg);
}
.user-select-container { text-align: center; width: 100%; max-width: 340px; }
.user-select-top { margin-bottom: 32px; }
.user-select-date { font-size: 0.9em; color: var(--text-muted); margin-bottom: 6px; }
.app-title { font-size: 2.2em; margin-bottom: 4px; font-weight: 700; color: var(--text); }
.user-select-motto { font-size: 0.88em; color: var(--accent-dark); font-style: italic; }

/* ── 访问码卡片 ── */
.access-code-card {
  background: var(--bg-card); border-radius: var(--radius);
  padding: 20px 24px 24px; box-shadow: var(--shadow);
  border: 1.5px solid var(--border); margin-bottom: 20px;
}
.access-code-label {
  font-size: 0.85em; color: var(--text-muted); margin-bottom: 10px;
  display: flex; align-items: center; justify-content: center; gap: 6px;
}
.access-code-input {
  width: 100%; padding: 12px 16px;
  border: 1.5px solid var(--border); border-radius: 10px;
  font-size: 1.15em; text-align: center; letter-spacing: 6px;
  background: var(--bg-secondary); color: var(--text);
  box-sizing: border-box;
}
.access-code-input:focus {
  border-color: var(--accent-dark); outline: none;
}

/* ── 分隔线 ── */
.divider-line {
  width: 60px; height: 2px; background: var(--border);
  margin: 0 auto 16px; border-radius: 2px;
}

/* ── 用户选择 ── */
.user-select-hint { color: var(--text-muted); margin-bottom: 20px; font-size: 0.9em; }
.user-buttons { display: flex; gap: 16px; justify-content: center; }
.user-btn {
  display: flex; flex-direction: column; align-items: center; gap: 10px;
  background: var(--bg-card); border: 2px solid var(--border);
  border-radius: var(--radius); padding: 24px 36px; box-shadow: var(--shadow);
  flex: 1; max-width: 140px;
}
.user-btn:active { opacity: 0.8; transform: scale(0.97); }
.user-btn-emoji { font-size: 2.8em; }
.user-btn-label { font-size: 1.05em; font-weight: 600; color: var(--text); }
