.gradient-label { display: block; font-size: 0.9em; opacity: 0.85; margin-bottom: 4px; }
.gradient-value { display: block; font-size: 3em; font-weight: 700; letter-spacing: 2px; }
.gradient-sub { display: block; font-size: 0.78em; opacity: 0.7; margin-top: 6px; font-weight: 400; }

.weekly-card {
  background: linear-gradient(135deg, var(--bg-card), var(--bg-secondary));
  border-radius: var(--radius); padding: 18px 20px; box-shadow: var(--shadow);
  margin-bottom: 20px; border: 2px solid var(--border);
}
.weekly-header { font-weight: 600; margin-bottom: 10px; color: var(--accent-dark); }
.stat-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; font-size: 0.95em; }
.weekly-sub { font-size: 0.82em; color: var(--text-muted); margin-top: 4px; }
.weekly-badge { margin-top: 10px; padding: 8px 14px; background: var(--accent); color: white; border-radius: 8px; font-size: 0.9em; font-weight: 600; text-align: center; }
.weekly-tip { margin-top: 6px; font-size: 0.82em; color: var(--text-muted); }

.rewards-list { display: flex; flex-direction: column; gap: 12px; }
.reward-item {
  display: flex; justify-content: space-between; align-items: center;
  background: var(--bg-card); border-radius: var(--radius); padding: 16px 20px;
  box-shadow: var(--shadow); border: 2px solid var(--border);
}
.reward-item.unlocked { border-color: var(--accent); background: #F0F7EE; }
@media (prefers-color-scheme: dark) { .reward-item.unlocked { background: #3A4840; } }
.reward-info { flex: 1; }
.reward-label { font-size: 1.05em; margin-bottom: 2px; color: var(--text); }
.reward-threshold { font-size: 0.82em; color: var(--text-muted); }
.claim-btn { background: var(--accent-dark); color: white; border: none; border-radius: var(--radius-sm); padding: 8px 20px; font-size: 0.9em; flex-shrink: 0; }
.claim-btn::after { border: none; }

.history-list { display: flex; flex-direction: column; gap: 8px; }
.history-item { display: flex; justify-content: space-between; align-items: center; background: var(--bg-card); border-radius: var(--radius-sm); padding: 10px 14px; border: 1px solid var(--border); }
.history-left { display: flex; flex-direction: column; gap: 2px; }
.history-label { font-weight: 500; color: var(--text); font-size: 0.9em; }
.history-date { font-size: 0.78em; color: var(--text-muted); }
.history-points { color: var(--accent-dark); font-weight: 600; font-size: 0.9em; }
