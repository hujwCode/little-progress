<view class="page-wrap">
  <view class="checkin-header">
    <view class="header-left">
      <text class="header-emoji">{{headerEmoji}}</text>
      <text class="header-name">{{headerName}}</text>
    </view>
    <view class="header-points">⭐ {{availablePoints}} 分</view>
  </view>

  <view wx:if="{{hasBroadcasts && curBroadcast}}" class="broadcast-ticker" bindtap="goBroadcast">
    <view class="ticker-icon"><text>📢</text></view>
    <view class="ticker-stage">
      <view class="ticker-item" wx:if="{{curBroadcast}}">
        <text class="ticker-text">{{curBroadcast.user_emoji}} {{curBroadcast.user_display_name}} {{curBroadcast.content}}</text>
        <text class="ticker-time">{{curBroadcast.type === 'manual' ? '💬' : '🔔'}} {{curBroadcast._timeAgo}}</text>
      </view>
    </view>
    <view class="ticker-more">更多 ›</view>
  </view>

  <block wx:if="{{loading}}">
    <view class="section-title">📋 今日打卡</view>
    <view class="skeleton skel-bar" style="width:60%"></view>
    <view class="skeleton skel-card"></view>
    <view class="skeleton skel-card"></view>
    <view class="skeleton skel-card"></view>
    <view class="skeleton skel-card"></view>
  </block>

  <view wx:elif="{{error}}" class="error-wrap">
    <text>加载失败，请检查网络</text>
    <view class="retry-btn" bindtap="loadData">重新加载</view>
  </view>

  <block wx:else>
    <view class="section-title">📋 今日打卡</view>
    <view class="checkin-list">
      <view wx:for="{{habits}}" wx:key="key" class="habit-item {{todayRecords[item.key] ? 'done' : ''}}" data-key="{{item.key}}" bindtap="onToggle">
        <view class="habit-check {{todayRecords[item.key] ? 'checked' : ''}}">
          <text wx:if="{{todayRecords[item.key]}}">✓</text>
        </view>
        <view class="habit-info">
          <view class="habit-label">{{item.label}}</view>
          <view class="habit-points">+{{item.points}} 分</view>
        </view>
      </view>
    </view>

    <view class="daily-summary">
      <view class="summary-item">
        <text class="summary-label">今日得分</text>
        <text class="summary-value">{{dayPoints}} / {{maxDayPoints}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-label">总积分</text>
        <text class="summary-value">{{availablePoints}}</text>
      </view>
    </view>
  </block>
</view>

<view wx:if="{{celebrate}}" class="celebrate-overlay">
  <view wx:for="{{celebrateItems}}" wx:key="*this" class="celebrate-particle" style="left:{{item.left}}%;animation-delay:{{item.delay}}s;animation-duration:{{item.duration}}s;font-size:{{item.size}}em;">
    <text>{{item.text}}</text>
  </view>
</view>
